{
  "name": "vitest-teamcity-reporter",
  "version": "0.4.1",
  "description": "A TeamCity reporter for vitest.",
  "repository": {
    "type": "git",
    "url": "https://github.com/eratio08/vitest-teamcity-reporter"
  },
  "keywords": [
    "vitest",
    "teamcity",
    "reporter"
  ],
  "files": [
    "lib/**/*"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "test": "vitest --run src/test/index.spec.ts",
    "build": "rolldown -c && tsc -p tsconfig.lib.json --emitDeclarationOnly",
    "lint": "biome check --write",
    "lint:ci": "biome check --reporter=github"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/utils": "^4.1.10",
    "rolldown": "^1.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "typescript": "4.x || 5.x || 6.x",
    "vitest": ">=3.0.0"
  },
  "author": "Eike Lurz<eike.lurz@tuta.io>",
  "license": "MIT"
}
